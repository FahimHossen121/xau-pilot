# App mode: paper or live
APP_MODE=paper

# Logging
LOG_LEVEL=INFO
TIMEZONE=UTC

# Trading scope
SYMBOL=XAUUSD
MAX_RISK_PER_TRADE=0.01
MAX_DAILY_LOSS=0.03

# MT5 (paper mode still uses demo account)
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=HFMarketsGlobal-Demo

# Gemini API (fundamental analysis)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-pro

# Safety
ENABLE_TRADING=false
