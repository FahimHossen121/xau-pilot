# App mode: paper or live
APP_MODE=paper

# Logging
LOG_LEVEL=INFO
TIMEZONE=UTC

# Trading scope
SYMBOL=XAUUSD
MAX_RISK_PER_TRADE=0.01
MAX_DAILY_LOSS=0.03
MAX_WEEKLY_LOSS=0.05
MAX_ACCOUNT_DRAWDOWN=0.12
MIN_BALANCE_FRACTION=0.70

# MT5 (paper mode still uses demo account)
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=HFMarketsGlobal-Demo

# News provider for AI confirmation: none, rss, or brave
NEWS_PROVIDER=none
RSS_FEED_URLS=

# Brave Search API (AI news context)
BRAVE_API_KEY=
BRAVE_NEWS_FRESHNESS=pd
BRAVE_NEWS_RESULTS_PER_QUERY=5

# Gemini API (fundamental analysis)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-pro
AI_HTF_REFRESH_HOURS=1

# Safety
ENABLE_TRADING=false
